[gd_scene format=3 uid="uid://d1snjq3mwjmpi"]

[sub_resource type="GDScript" id="GDScript_5a5xp"]
script/source = "extends Control

@onready var aviso_na_tela = $AvisoNaTela
@onready var visualizar_codigo = $Background/Terminal/CodigosCorretos
@onready var editar_codigo = $Background/Terminal/CodigosAlunos

# --- NOVOS NÓS DE INTERFACE (HUD) ---
# Você precisará adicionar esses Labels na sua cena para mostrar os dados!
@onready var texto_reputacao = $HBoxContainer2/TextoReputacao
@onready var texto_progresso = $HBoxContainer2/TextoProgresso
@onready var texto_tempo = $HBoxContainer2/TextoTempo

var reputacao: int = 0
var avaliacoes_feitas: int = 0
var max_avaliacoes: int = 10

var tarefa_atual: Dictionary
var pode_interagir: bool = false 

# --- VARIÁVEIS DO TIMER ---
var tempo_restante: float = 60.0
var jogo_encerrado: bool = false # Impede que o timer continue rodando após o fim


var banco_de_dados: Array = [
	# ---------------------------------------------------------
	# CÓDIGOS CORRETOS (AÇÃO: \"aprovar\")
	# ---------------------------------------------------------
	{
		# Básico: Iniciando o sistema corretamente
		\"codigo_esquerdo\": \"vida = 100\\nprint('Iniciando...')\",
		\"codigo_direito\": \"vida = 100\\nprint('Iniciando...')\",
		\"acao_correta\": \"aprovar\"
	},
	{
		# Lógica de Movimento
		\"codigo_esquerdo\": \"posicao_x = 0\\nvelocidade = 5\\nposicao_x += velocidade\",
		\"codigo_direito\": \"posicao_x = 0\\nvelocidade = 5\\nposicao_x += velocidade\",
		\"acao_correta\": \"aprovar\"
	},
	{
		# Verificação de Inventário
		\"codigo_esquerdo\": \"if inventario.has('chave_mestra'):\\n\\tabrir_porta_principal()\",
		\"codigo_direito\": \"if inventario.has('chave_mestra'):\\n\\tabrir_porta_principal()\",
		\"acao_correta\": \"aprovar\"
	},
	{
		# Cálculo de Dano com Armadura
		\"codigo_esquerdo\": \"dano = forca_inimigo - armadura_player\\nif dano < 0:\\n\\tdano = 0\",
		\"codigo_direito\": \"dano = forca_inimigo - armadura_player\\nif dano < 0:\\n\\tdano = 0\",
		\"acao_correta\": \"aprovar\"
	},
	{
		# Sistema de Level Up
		\"codigo_esquerdo\": \"xp += 50\\nif xp >= 100:\\n\\tlevel_up()\\n\\txp = 0\",
		\"codigo_direito\": \"xp += 50\\nif xp >= 100:\\n\\tlevel_up()\\n\\txp = 0\",
		\"acao_correta\": \"aprovar\"
	},

	# ---------------------------------------------------------
	# CÓDIGOS COM ERROS (AÇÃO: \"recusar\")
	# ---------------------------------------------------------
	{
		# Erro Lógico: Dano curando o inimigo (Negativo)
		\"codigo_esquerdo\": \"dano = 10\",
		\"codigo_direito\": \"dano = -10\",
		\"acao_correta\": \"recusar\"
	},
	{
		# Erro de Sintaxe: Faltando os dois pontos (:) do IF
		\"codigo_esquerdo\": \"if jogador_vivo:\\n\\ttocar_musica()\",
		\"codigo_direito\": \"if jogador_vivo\\n\\ttocar_musica()\",
		\"acao_correta\": \"recusar\"
	},
	{
		# Erro de Digitação (Typo): Variável escrita errada
		\"codigo_esquerdo\": \"municao = 30\\natirar(municao)\",
		\"codigo_direito\": \"municao = 30\\natirar(muncio)\",
		\"acao_correta\": \"recusar\"
	},
	{
		# Erro Matemático: Ordem de precedência errada (faltou parênteses)
		\"codigo_esquerdo\": \"media = (nota1 + nota2) / 2\",
		\"codigo_direito\": \"media = nota1 + nota2 / 2\",
		\"acao_correta\": \"recusar\"
	},
	{
		# Erro Crítico: Loop Infinito (a energia sobe em vez de descer)
		\"codigo_esquerdo\": \"while energia > 0:\\n\\tcorrer()\\n\\tenergia -= 1\",
		\"codigo_direito\": \"while energia > 0:\\n\\tcorrer()\\n\\tenergia += 1\",
		\"acao_correta\": \"recusar\"
	},
	{
		# Erro de Lógica Invertida: Morrendo quando a vida está cheia
		\"codigo_esquerdo\": \"if vida <= 0:\\n\\ttela_game_over()\",
		\"codigo_direito\": \"if vida >= 100:\\n\\ttela_game_over()\",
		\"acao_correta\": \"recusar\"
	},

	# ---------------------------------------------------------
	# CÓDIGOS HACKER (AÇÃO: \"verificar\")
	# ---------------------------------------------------------
	{
		# Hacker: Ignorando a checagem de usuário/senha
		\"codigo_esquerdo\": \"login(usuario, senha)\\naguardar_autenticacao()\",
		\"codigo_direito\": \"BYPASS_SECURITY = true\\nFORCE_ADMIN_ACCESS()\",
		\"acao_correta\": \"verificar\"
	},
	{
		# Hacker: Tentativa de apagar o banco de dados (Drop Table)
		\"codigo_esquerdo\": \"carregar_perfil_jogador(id_usuario)\\nmostrar_hud()\",
		\"codigo_direito\": \"db.execute('DROP TABLE usuarios;')\\nlimpar_logs()\",
		\"acao_correta\": \"verificar\"
	},
	{
		# Hacker: Injetando dinheiro infinito
		\"codigo_esquerdo\": \"moedas_ganhas = calcular_recompensa()\\nadicionar_saldo(moedas_ganhas)\",
		\"codigo_direito\": \"moedas_ganhas = 9999999\\nadicionar_saldo(moedas_ganhas)\",
		\"acao_correta\": \"verificar\"
	},
	{
		# Hacker: Roubo de dados (Exfiltração)
		\"codigo_esquerdo\": \"salvar_progresso_local()\\nprint('Salvo com sucesso')\",
		\"codigo_direito\": \"enviar_dados_jogador('http://servidor-pirata.com/roubo')\\nsalvar_progresso_local()\",
		\"acao_correta\": \"verificar\"
	}
]

func _ready() -> void:
	aviso_na_tela.hide()
	editar_codigo.editable = false 
	
	# Atualiza o HUD logo no início
	atualizar_hud()
	carregar_nova_tarefa()

# --- O CRONÔMETRO ---
# Esta função roda sozinha a cada frame (60 vezes por segundo)
func _process(delta: float) -> void:
	if jogo_encerrado:
		return # Se o jogo já acabou, não faz mais nada
		
	# O 'delta' é o tempo exato que passou desde o último frame (ex: 0.016s)
	tempo_restante -= delta
	
	# Atualiza o texto do tempo arredondando para inteiro (int)
	texto_tempo.text = \"Tempo: \" + str(int(tempo_restante)) + \"s\"
	
	# Verifica se o tempo acabou
	if tempo_restante <= 0:
		tempo_restante = 0
		texto_tempo.text = \"Tempo: 0s\"
		encerrar_fase(\"TEMPO ESGOTADO!\")


# --- LÓGICA PRINCIPAL ---
func carregar_nova_tarefa() -> void:
	if jogo_encerrado:
		return
		
	tarefa_atual = banco_de_dados.pick_random()
	visualizar_codigo.text = tarefa_atual[\"codigo_esquerdo\"]
	editar_codigo.text = tarefa_atual[\"codigo_direito\"]
	
	pode_interagir = true 

func processar_escolha(acao_escolhida: String) -> void:
	if not pode_interagir or jogo_encerrado:
		return 
		
	pode_interagir = false 
	avaliacoes_feitas += 1
	
	if acao_escolhida == tarefa_atual[\"acao_correta\"]:
		reputacao += 10
		if acao_escolhida == \"verificar\":
			mostrar_aviso(\"[color=yellow]CÓDIGO ENVIADO PARA ANÁLISE[/color]\\nReputação: \" + str(reputacao))
		else:
			mostrar_aviso(\"[color=green]AVALIAÇÃO CORRETA![/color]\\nReputação: \" + str(reputacao))
	else:
		reputacao = max(0, reputacao - 10)
		mostrar_aviso(\"[color=red]AVALIAÇÃO INCORRETA![/color]\\nReputação: \" + str(reputacao))
	
	atualizar_hud()
	
	# Verifica se bateu a meta de 10 avaliações ANTES do tempo acabar
	if avaliacoes_feitas >= max_avaliacoes:
		encerrar_fase(\"INSPEÇÃO CONCLUÍDA!\")
	else:
		visualizar_codigo.text = \"\"
		editar_codigo.text = \"\"
		await get_tree().create_timer(2.0).timeout 
		carregar_nova_tarefa()


# --- FUNÇÃO DE ENCERRAMENTO (NOVA) ---
func encerrar_fase(mensagem_final: String) -> void:
	jogo_encerrado = true
	pode_interagir = false
	
	# Mostra o aviso final na tela
	aviso_na_tela.text = \"[color=cyan]\" + mensagem_final + \"[/color]\\nReputação Final: \" + str(reputacao)
	aviso_na_tela.show()
	
	# Espera 3 segundos para o jogador ler a mensagem final
	await get_tree().create_timer(3.0).timeout
	
	# Troca de cena
	get_tree().change_scene_to_file(\"res://scenes/jogo/edicao_codigos.tscn\")


func mostrar_aviso(mensagem: String) -> void:
	aviso_na_tela.text = mensagem
	aviso_na_tela.show()
	await get_tree().create_timer(2.0).timeout
	# Só esconde o aviso se o jogo ainda estiver rolando
	if not jogo_encerrado:
		aviso_na_tela.hide()

func atualizar_hud() -> void:
	texto_reputacao.text = \"Reputação: \" + str(reputacao)
	texto_progresso.text = \"Arquivos: \" + str(avaliacoes_feitas) + \"/\" + str(max_avaliacoes)

# --- BOTÕES ---
func _on_botao_aprovar_pressed() -> void:
	processar_escolha(\"aprovar\")

func _on_botao_recusar_pressed() -> void:
	processar_escolha(\"recusar\")

func _on_botao_verificar_pressed() -> void:
	processar_escolha(\"verificar\")

func _on_botao_power_pressed() -> void:
	get_tree().change_scene_to_file(\"res://scenes/jogo/cena_principal.tscn\")
"

